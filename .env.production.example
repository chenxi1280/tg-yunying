# TG 运营管理平台生产环境模板
# 首次部署会复制到服务器 /data/tgyunying/shared/.env，请在服务器上填写真实值。

APP_ENV=production
TZ=Asia/Shanghai

# Host / Nginx
TGYUNYING_WEB_HOST=tgyunying.example.com
TGYUNYING_BACKEND_BIND_HOST=127.0.0.1
TGYUNYING_BACKEND_HOST_PORT=18090
TGYUNYING_FRONTEND_STATIC_BASE_DIR=/data/infra/www/tgyunying.example.com
CORS_ORIGINS=https://tgyunying.example.com

# Shared infra on the Silicon Valley server
INFRA_NETWORK_NAME=infra_default
DATABASE_URL=postgresql+psycopg://tgyunying_app:change-me@infra-postgres:5432/tgyunying?connect_timeout=3
REDIS_URL=redis://infra-redis:6379/3
QUEUE_BACKEND=redis

# Security
SESSION_SECRET_KEY=change-me-to-a-random-64-char-secret
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-first-start
ADMIN_BOOTSTRAP_EMAIL=

# Telegram
TG_GATEWAY_MODE=telethon
TG_API_ID=
TG_API_HASH=
SEED_TG_DEVELOPER_APP_FROM_ENV=false

# Runtime
ENABLE_EMBEDDED_WORKER=false
WORKER_DRAIN_LIMIT=100
WORKER_INTERVAL_SECONDS=2.0
RUNTIME_METRIC_RETENTION_DAYS=3
RUNTIME_METRIC_RETENTION_BATCH_SIZE=20000
RUNTIME_METRIC_CLEANUP_INTERVAL_SECONDS=60
AUTO_MIGRATE_ON_START=false
SEED_DEMO_DATA=false

# Legacy compatibility switches, keep disabled unless doing a migration drill.
ENABLE_LEGACY_CAMPAIGN_WORKER=false
ENABLE_LEGACY_OPERATION_TASK_WORKER=false
ENABLE_LEGACY_CAMPAIGN_ROUTES=false
ENABLE_LEGACY_OPERATION_TASK_ROUTES=false
ENABLE_LEGACY_REVIEW_ROUTES=false

# Post deploy checks
POST_DEPLOY_CHECKS_ENABLED=true
TGYUNYING_CHECK_HOST_NGINX=true
TGYUNYING_CHECK_PUBLIC_URLS=true
TGYUNYING_CHECK_ATTEMPTS=12
TGYUNYING_CHECK_RETRY_DELAY_SECONDS=5
