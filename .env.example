# ── App ──
APP_ENV=development
TZ=Asia/Shanghai

# ── Database ──
# PostgreSQL:
DATABASE_URL=postgresql+psycopg://tg_yunying:tg_yunying@127.0.0.1:5432/tg_yunying?connect_timeout=3
# Test database must also be PostgreSQL when running pytest:
# TEST_DATABASE_URL=postgresql+psycopg://tg_yunying_test:tg_yunying_test@127.0.0.1:5432/tg_yunying_test?connect_timeout=3
# Optional local demo business data (TG accounts/groups/materials):
# SEED_DEMO_DATA=false

# ── Redis (optional, for queue + captcha) ──
# REDIS_URL=redis://127.0.0.1:6379/0
# QUEUE_BACKEND=redis

# ── Security ──
# SESSION_SECRET_KEY=<generate a random 64-char string>
# First empty-database admin account. Existing users are never overwritten on startup.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-before-production
# Optional email for the bootstrap admin. If omitted and username is not an email,
# the system uses <username>@bootstrap.local internally.
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com

# ── Telegram ──
# TG_API_ID=<your telegram api id>
# TG_API_HASH=<your telegram api hash>
# SEED_TG_DEVELOPER_APP_FROM_ENV=false
# TG_GATEWAY_MODE=mock

# ── CORS ──
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ── Storage ──
# MEDIA_ROOT=./media
